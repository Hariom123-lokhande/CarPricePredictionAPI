@model dynamic
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Signup | Car AI Estimator</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #10b981;
            --bg: #0f172a;
            --card-bg: #1e293b;
            --text: #f8fafc;
            --text-muted: #94a3b8;
        }

        body { 
            font-family: 'Outfit', sans-serif; 
            background: var(--bg); 
            color: var(--text);
            display: flex; 
            align-items: center; 
            justify-content: center; 
            height: 100vh; 
            margin: 0; 
        }

        .login-card { 
            background: var(--card-bg); 
            padding: 2.5rem; 
            border-radius: 20px; 
            box-shadow: 0 20px 50px rgba(0,0,0,0.5); 
            width: 100%; 
            max-width: 400px; 
            text-align: center;
            border: 1px solid rgba(255,255,255,0.05);
        }

        h2 { 
            margin-bottom: 2rem; 
            font-size: 2rem; 
            background: linear-gradient(135deg, #fff 0%, #10b981 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        input { 
            width: 100%; 
            padding: 0.85rem 1rem; 
            margin-bottom: 1.25rem; 
            background: #0f172a;
            border: 1px solid #334155; 
            border-radius: 10px; 
            color: white;
            font-family: inherit;
        }

        input:focus { outline: none; border-color: var(--primary); }

        button { 
            background: var(--primary); 
            color: white; 
            border: none; 
            padding: 1rem; 
            border-radius: 10px; 
            cursor: pointer; 
            width: 100%; 
            font-weight: 700; 
            font-size: 1rem;
            transition: all 0.3s;
            margin-bottom: 1rem;
        }

        button:hover { background: #059669; transform: translateY(-2px); }

        .signup-link { color: var(--text-muted); font-size: 0.9rem; }
        .signup-link a { color: var(--primary); text-decoration: none; font-weight: 600; }

        #error { color: #ef4444; margin-top: 1rem; font-size: 0.9rem; min-height: 1.2em; }
    </style>
</head>
<body>
    <div class="login-card">
        <h2>Join Car AI</h2>
        <input type="text" id="username" placeholder="Username" />
        <input type="password" id="password" placeholder="Password" />
        <button type="button" onclick="signup()">Create Account ✨</button>
        <p class="signup-link">Already have an account? <a href="/Auth/Login">Sign In</a></p>
        <div id="error"></div>
    </div>
    <script src="/js/auth.js"></script>
</body>
</html>
